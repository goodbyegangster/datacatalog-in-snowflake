# このファイルはテンプレートです。実体の .streamlit/secrets.toml は make が .env から生成します。

[connections.snowflake]
account = "${SNOWFLAKE_ACCOUNT_IDENTIFIER}"
user = "${SNOWFLAKE_MY_USER_NAME}"
password = "${SNOWFLAKE_MY_USER_PASSWORD}"
warehouse = "${DATACATALOG_WAREHOUSE_NAME}"
database = "${DATACATALOG_DATABASE_NAME}"
schema = "PUBLIC"
authenticator = "USERNAME_PASSWORD_MFA"
