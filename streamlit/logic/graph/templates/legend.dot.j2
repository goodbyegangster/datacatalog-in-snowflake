digraph G {
  rankdir=LR;
  graph [fontname="sans-serif", margin=0];
  node [fontname="sans-serif"];
  edge [style=invis];
  subgraph cluster_legend {
    label="凡例";
    fontsize=10;
    fontname="sans-serif";
    color="#D0D7DE";
    style="rounded,dashed";
    margin=6;
    "__legend_user__" [label="User", shape=oval, style="filled", fillcolor="#E3F2FD", fontsize=10, width=0.5, height=0.25, margin=0.04];
    "__legend_role__" [label="Role", shape=box, style="rounded,filled", fillcolor="white", fontsize=10, width=0.5, height=0.25, margin=0.04];
    "__legend_asset__" [label="Asset", shape=box, style="rounded,filled", fillcolor="#FFF3E0", fontsize=10, width=0.5, height=0.25, margin=0.04];
    "__legend_user__" -> "__legend_role__";
    "__legend_role__" -> "__legend_asset__";
  }
}
